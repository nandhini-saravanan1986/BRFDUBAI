	<queryString>
		<![CDATA[select rownum as srl_num,to_char(tran_date,'DD-MM-YYYY') as tran_date,tran_id,part_tran_type,to_char(value_date,'DD-MM-YYYY') as Value_date,tran_particular,decode (part_tran_type,'D',-tran_amt,'C','') as debit_amount,decode (part_tran_type,'C',tran_amt,'D','') as credit_amount,tran_crncy_code from HTD 
 where acid =$P{ACID}and Tran_date between $P{FROMDATE} and $P{TODATE}  order by tran_date desc]]>
